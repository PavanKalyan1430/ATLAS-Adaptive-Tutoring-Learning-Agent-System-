# ==========================================
# A.R.C.H.E.R. Environment Variables
# Copy this file to .env and fill in your values
# ==========================================

# 1. Groq API Keys (For Fast/Agentic LLM)
# We use 3 keys for round-robin load balancing to avoid rate limits
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

# 3. Qdrant Vector Database
QDRANT_URL=http://localhost:6333
